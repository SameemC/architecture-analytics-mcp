# ─────────────────────────────────────────────────────────────────────────────
# project-risk-mcp  —  .env template
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server connection ─────────────────────────────────────────────────────
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DB=ProjectData
SQL_UID=reader
SQL_PWD=

# ── Primary table ─────────────────────────────────────────────────────────────
# Fully qualified table name containing your project data.
PRIMARY_TABLE=dbo.Projects

# ── Standard column name mappings ─────────────────────────────────────────────
# Override these if your column names differ from the defaults.
COL_PROJECT_ID=Project_ID
COL_PROJECT_NAME=Project_Name
COL_TYPOLOGY=Market_Sector
COL_STATUS=Project_Status
COL_SQFT=Gross_Square_Footage
COL_LOCATION=State
COL_YEAR=Year

# ── Status values ─────────────────────────────────────────────────────────────
# What value in your status column means "actively in delivery"?
# What value means "completed / closed"?
ACTIVE_STATUS_VALUE=Active
COMPLETED_STATUS_VALUE=Completed

# ── Phase actuals and planned fee column pairs ─────────────────────────────────
# These are the most critical settings for this tool.
# Format: PHASE:ColumnName,PHASE:ColumnName,...
#
# ACTUALS_COLS — columns containing fee spent/billed/incurred to date per phase.
# PLANNED_COLS — columns containing the original planned/budgeted fee per phase.
#
# The tool auto-detects these if left blank, but explicit mapping is recommended
# if your column names don't follow common patterns.
#
# Example:
# ACTUALS_COLS=CONCEPT:Concept_Actuals,SD:SD_Actuals,DD:DD_Actuals,CD:CD_Actuals,CA:CA_Actuals
# PLANNED_COLS=CONCEPT:Concept_Labor_Fee,SD:SD_Fee,DD:DD_Fee,CD:CD_Fee,CA:CA_Fee
ACTUALS_COLS=
PLANNED_COLS=

# ── Phase percent-complete columns (optional) ─────────────────────────────────
# If your table tracks phase % complete, map them here.
# Used for context in the analyst interpretation — not required for burn rate.
# Values can be 0–100 or 0.0–1.0; the tool normalizes automatically.
#
# Example:
# PCT_COLS=SD:SD_Pct_Complete,DD:DD_Pct_Complete,CD:CD_Pct_Complete
PCT_COLS=

# ── Risk classification thresholds ────────────────────────────────────────────
# At what multiple of the historical P75 burn rate does each risk level trigger?
# Defaults produce: NORMAL <1.10 | ELEVATED 1.10–1.25 | AT RISK 1.25–1.50 | CRITICAL >1.50
RISK_ELEVATED_MULT=1.10
RISK_AT_RISK_MULT=1.25
RISK_CRITICAL_MULT=1.50

# ── Benchmark pool settings ───────────────────────────────────────────────────
# Minimum completed comparable projects before relaxing sqft/typology filters.
MIN_BENCH_COMPS=5
# Square footage tolerance for benchmark matching (±50% default).
SQFT_TOLERANCE=0.50

# ── LLM connection ─────────────────────────────────────────────────────────────
# LM Studio (local) — default. Replace with OpenAI or any OpenAI-compatible API.
LM_BASE_URL=http://localhost:1234/v1
LM_MODEL=lmstudio-community/Meta-Llama-3-8B-Instruct
LM_API_KEY=lm-studio
LM_TEMPERATURE=0.15
