# ─────────────────────────────────────────────────────────────────────────────
# phase-fee-estimator-mcp  —  .env configuration
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server connection ─────────────────────────────────────────────────────
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DB=ProjectData
SQL_UID=reader
SQL_PWD=

# ── Primary table ─────────────────────────────────────────────────────────────
PRIMARY_TABLE=dbo.Projects

# ── Column name mappings ──────────────────────────────────────────────────────
COL_PROJECT_ID=Project_ID
COL_PROJECT_NAME=Project_Name
COL_TYPOLOGY=Market_Sector
COL_STATUS=Project_Status
COL_SQFT=Gross_Square_Footage
COL_LOCATION=State
COL_YEAR=Year

# ── Phase fee columns ─────────────────────────────────────────────────────────
# Optional. If not set, the server attempts to auto-detect from your schema.
# Format: PHASE_LABEL:column_name,PHASE_LABEL:column_name,...
# PHASE_COLS=CONCEPT:Concept_Labor_Fee,SD:SD_Fee,DD:DD_Fee,CD:CD_Fee,CA:CA_Fee
# PHASE_COLS=

# ── Estimation tuning ─────────────────────────────────────────────────────────
MIN_COMPS=3
SQFT_TOLERANCE=0.40

# ── LLM connection ────────────────────────────────────────────────────────────
LM_BASE_URL=http://localhost:1234/v1
LM_MODEL=lmstudio-community/Chosen-Model-Here
LM_API_KEY=lm-studio
LLM_TEMPERATURE=0.15
