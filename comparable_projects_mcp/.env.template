# ─────────────────────────────────────────────────────────────────────────────
# comparable-projects-mcp  —  .env configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────


# ── SQL Server connection ─────────────────────────────────────────────────────

SQL_SERVER=localhost
SQL_PORT=1433
SQL_DB=ProjectData
SQL_UID=reader
SQL_PWD=


# ── Primary table ─────────────────────────────────────────────────────────────
# Fully qualified table name containing your project data.

PRIMARY_TABLE=dbo.Projects


# ── Column name mappings ──────────────────────────────────────────────────────
# Override these if your column names differ from the defaults.
# Run validate_connection to check which columns are detected.

COL_PROJECT_ID=Project_ID
COL_PROJECT_NAME=Project_Name
COL_TYPOLOGY=Market_Sector
COL_STATUS=Project_Status
COL_SQFT=Gross_Square_Footage
COL_LOCATION=State
COL_YEAR=Year
COL_CONST_COST=Estimated_Construction_Cost

# Display-only columns (shown on results but not used for scoring)
COL_CLIENT=Client
COL_DESIGN_PRIN=Design_Principal
COL_CITY=City


# ── Phase fee columns ─────────────────────────────────────────────────────────
# Optional. If not set, the server attempts to auto-detect phase fee columns
# from your schema using naming heuristics.
#
# Format: PHASE_LABEL:column_name,PHASE_LABEL:column_name,...
# Example:
# PHASE_COLS=CONCEPT:Concept_Labor_Fee,SD:SD_Fee,DD:DD_Fee,CD:CD_Fee,CA:CA_Fee

# PHASE_COLS=


# ── Similarity engine tuning ──────────────────────────────────────────────────

# Maximum number of ranked results to return.
MAX_RESULTS=10

# Number of SQL candidates pulled before numeric scoring.
# Increase if your database is large and you want a broader scoring pool.
CANDIDATE_POOL=200

# Sqft filter tolerance for the SQL candidate pass (±fraction).
# Default ±50% — wider than Tool 2 to give the scorer more to work with.
# Reduce if you have a large, dense database and want tighter candidates.
SQFT_TOLERANCE=0.50

# Scoring dimension weights. Values are auto-normalised so they don't need
# to sum to exactly 1.0. Unused dimensions (no target value provided) have
# their weight redistributed to the remaining active dimensions.
#
# Dimensions:
#   sqft        — gross square footage log-ratio distance
#   const_cost  — estimated construction cost log-ratio distance
#   year        — project year linear proximity
#   location    — same state binary match
#
# Example: if construction cost data is unreliable, shift weight to sqft:
# SCORE_WEIGHTS=sqft:0.60,const_cost:0.10,year:0.15,location:0.15
SCORE_WEIGHTS=sqft:0.45,const_cost:0.25,year:0.15,location:0.15


# ── LLM connection ────────────────────────────────────────────────────────────
# Supports LM Studio (local) or any OpenAI-compatible API endpoint.

LM_BASE_URL=http://localhost:1234/v1
LM_MODEL=lmstudio-community/Chosen-Model-Here
LM_API_KEY=lm-studio
LLM_TEMPERATURE=0.15
